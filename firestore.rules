rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isPublishedBusiness() {
      return resource.data.status == 'published';
    }

    match /businesses/{businessId} {
      allow read: if isPublishedBusiness();
      allow create, update, delete: if false;
    }

    match /categories/{categoryId} {
      allow read: if resource.data.isActive == true;
      allow create, update, delete: if false;
    }

    match /certificationBodies/{bodyId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /amenityTaxonomy/{amenityId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /slugs/{slug} {
      allow read, create, update, delete: if false;
    }

    function isPublishedMosque() {
      return resource.data.status == 'published';
    }

    match /mosques/{mosqueId} {
      allow read: if isPublishedMosque();
      // Writes are gated to the Admin SDK (Server Actions) — Firestore rules
      // never permit client writes; the admin allowlist runs server-side.
      allow create, update, delete: if false;
    }

    match /geocodeCache/{cacheId} {
      allow read, create, update, delete: if false;
    }

    match /favoriteStats/{statsId} {
      // Public read so signed-out visitors see the like count next to ayahs.
      // Writes only via server actions (Admin SDK bypasses these rules).
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /businessReports/{reportId} {
      allow create: if request.resource.data.keys().hasAll(['businessId', 'reason', 'createdAt'])
                    && request.resource.data.businessId is string
                    && request.resource.data.reason in ['not_halal','closed','wrong_info','offensive','duplicate','other']
                    && (!('note' in request.resource.data) || request.resource.data.note is string);
      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
